# omx-bridge HTTP API URL
BRIDGE_URL=http://localhost:3992

# HMAC-SHA256 서명 검증용 시크릿 (omx-bridge의 BRIDGE_CALLBACK_SECRET과 동일)
BRIDGE_CALLBACK_SECRET=

# omx-bridge가 claude 모드일 때 job 완료 알림을 수신할 포트
# CLAUDE_NOTIFY_URL=http://127.0.0.1:${WEBHOOK_PORT}/notify 형태로 omx-bridge에 설정
WEBHOOK_PORT=3993

# Claude Code Channels preview 알림을 활성화하려면 true로 설정
# Claude Code 실행 시 channel loading 옵션도 별도로 필요
ENABLE_CLAUDE_CHANNEL=false

# omx_get_notifications를 호출하지 않을 때 보관할 최대 완료 알림 수
MAX_NOTIFICATION_QUEUE_SIZE=200
