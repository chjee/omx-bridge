PORT=3992
BRIDGE_JOBS_DIR=.omx/state/bridge-jobs
OMX_COMMAND=omx
BRIDGE_JOB_POLL_INTERVAL_MS=100
BRIDGE_JOB_TIMEOUT_MS=900000
BRIDGE_MAX_OUTPUT_CHARS=32000

# 완료 알림 모드: openclaw(기본) | claude
# openclaw: OpenClaw hooks + 텔레그램 직접 전송 (현재 운영 중)
# claude: CLAUDE_NOTIFY_URL로 webhook POST, Telegram 설정이 있으면 fallback push 병행
NOTIFY_MODE=openclaw

# claude 모드 전용: job 완료 알림 수신 URL
# - omx-dispatch(CLI): 기동 시 동적 할당된 포트(12000-12999)를 사용
#   예) CLAUDE_NOTIFY_URL=http://127.0.0.1:12345/notify
# - Synapse: SYNAPSE_NOTIFY_PORT 값을 사용
#   예) CLAUDE_NOTIFY_URL=http://127.0.0.1:3994/notify
# CLAUDE_NOTIFY_URL=http://127.0.0.1:<port>/notify

# Telegram 알림 (openclaw 직접 알림 또는 claude 모드 fallback push, 선택)
TELEGRAM_BOT_TOKEN=
TELEGRAM_NOTIFY_CHAT_ID=

# OpenClaw hooks 알림 (openclaw 모드, 선택) - 로컬 gateway로 hooks 송신
OPENCLAW_HOOKS_URL=http://localhost:18789/hooks/agent
OPENCLAW_HOOKS_TOKEN=
OPENCLAW_HOOKS_SESSION_KEY=agent:main:telegram:direct:<chat-id>
