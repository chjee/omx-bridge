PORT=3992
BRIDGE_JOBS_DIR=.omx/state/bridge-jobs
OMX_COMMAND=omx
BRIDGE_JOB_POLL_INTERVAL_MS=100
BRIDGE_JOB_TIMEOUT_MS=900000
BRIDGE_MAX_OUTPUT_CHARS=32000

# Telegram 알림 (선택)
TELEGRAM_BOT_TOKEN=
TELEGRAM_NOTIFY_CHAT_ID=

# OpenClaw hooks 알림 (선택) - 로컈 gateway로 hooks 송신
OPENCLAW_HOOKS_URL=http://localhost:18789/hooks/agent
OPENCLAW_HOOKS_TOKEN=
OPENCLAW_HOOKS_SESSION_KEY=agent:main:telegram:direct:<chat-id>
