PORT=3992
# HTTP 바인드 호스트 (기본 127.0.0.1: 로컬 전용).
# 외부 호스트 노출이 필요한 경우에만 0.0.0.0 등으로 변경하되,
# POST /jobs는 현재 무인증이므로 노출 시 별도 인증 가드 도입 필요.
BRIDGE_HOST=127.0.0.1
BRIDGE_JOBS_DIR=.omx/state/bridge-jobs
OMX_COMMAND=omx
BRIDGE_JOB_POLL_INTERVAL_MS=100
BRIDGE_JOB_TIMEOUT_MS=900000
BRIDGE_MAX_OUTPUT_CHARS=32000
# SIGTERM 후 SIGKILL을 보내기까지 대기 시간 (ms, 기본 5000)
BRIDGE_SIGKILL_GRACE_MS=5000

# Bearer 토큰: POST /jobs, GET /jobs[/:id], POST /jobs/:id/cancel 보호.
# 미설정 시 가드 비활성(default-allow). BRIDGE_HOST=127.0.0.1 + 신뢰 환경에서는
# 비워둬도 무방하지만, 외부 호스트 노출이나 다중 사용자 환경에서는 필수.
# 호출자(omx-dispatch, omx-bridge-plugin, synapse가 spawn하는 worker 환경 등)
# 모두 동일 값을 환경변수/설정으로 가져야 함.
# /callback 라우트는 BRIDGE_CALLBACK_SECRET HMAC을 별도로 사용하므로 영향 없음.
# BRIDGE_API_TOKEN=replace-with-random-token

# 완료 알림 모드: openclaw(기본) | claude
# openclaw: OpenClaw hooks + 텔레그램 직접 전송 (현재 운영 중)
# claude: per-job notifyUrl 또는 CLAUDE_NOTIFY_URL로 webhook POST,
#         Telegram 설정이 있으면 fallback push 병행
NOTIFY_MODE=openclaw

# claude 모드 전용: job 완료 알림 수신 URL (fallback)
# Claude webhook URL 결정 우선순위:
#   1) per-job notifyUrl (caller가 잡 페이로드에 포함시켜 전달)
#   2) CLAUDE_NOTIFY_URL (notifyUrl이 없는 caller를 위한 fallback)
# omx-dispatch는 매 호출마다 자체 webhook URL을 notifyUrl로 전송하므로
# dispatch만 사용하는 환경에서는 이 값이 사실상 사용되지 않음.
# 다른 caller(synapse 등)가 notifyUrl을 보내지 않을 때만 fallback으로 동작.
# 예) CLAUDE_NOTIFY_URL=http://127.0.0.1:3994/notify
# CLAUDE_NOTIFY_URL=http://127.0.0.1:<port>/notify

# Telegram 알림 (openclaw 직접 알림 또는 claude 모드 fallback push, 선택)
TELEGRAM_BOT_TOKEN=
TELEGRAM_NOTIFY_CHAT_ID=

# OpenClaw hooks 알림 (openclaw 모드, 선택) - 로컬 gateway로 hooks 송신
OPENCLAW_HOOKS_URL=http://localhost:18789/hooks/agent
OPENCLAW_HOOKS_TOKEN=
OPENCLAW_HOOKS_SESSION_KEY=agent:main:telegram:direct:<chat-id>
