{
  "name": "omx-bridge",
  "version": "0.1.0",
  "private": true,
  "description": "OpenClaw to OMX bridge service",
  "license": "UNLICENSED",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/main.js",
    "start:dev": "ts-node -r tsconfig-paths/register src/main.ts",
    "test": "jest --runInBand",
    "test:watch": "jest --watch",
    "test:unit": "jest --runInBand test/unit",
    "test:e2e": "jest --runInBand --testPathPatterns=test/.*\\.e2e-spec\\.ts$",
    "smoke:runtime": "npm run build && npm --prefix omx-dispatch run build && npm --prefix omx-bridge-plugin run build && node scripts/runtime-smoke.js",
    "verify:runtime": "npm run smoke:runtime",
    "verify": "npm run verify:root && npm run verify:dispatch && npm run verify:plugin",
    "verify:root": "npm test && npm run build",
    "verify:dispatch": "npm --prefix omx-dispatch run typecheck && npm --prefix omx-dispatch run build && npm --prefix omx-dispatch test",
    "verify:plugin": "npm --prefix omx-bridge-plugin run typecheck && npm --prefix omx-bridge-plugin run build && npm --prefix omx-bridge-plugin test"
  },
  "dependencies": {
    "@nestjs/common": "^11.1.6",
    "@nestjs/config": "^4.0.3",
    "@nestjs/core": "^11.1.6",
    "@nestjs/platform-express": "^11.1.6",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.2",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2"
  },
  "devDependencies": {
    "@nestjs/testing": "^11.1.6",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/node": "^24.5.2",
    "@types/supertest": "^6.0.3",
    "jest": "^30.1.3",
    "supertest": "^7.1.4",
    "ts-jest": "^29.4.1",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.9.2"
  }
}
