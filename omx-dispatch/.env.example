# omx-bridge HTTP API URL
BRIDGE_URL=http://localhost:3992

# HMAC-SHA256 서명 검증용 시크릿 (omx-bridge의 BRIDGE_CALLBACK_SECRET과 동일)
BRIDGE_CALLBACK_SECRET=

# Bearer 토큰: omx-bridge가 BRIDGE_API_TOKEN을 설정한 경우 동일 값 필요.
# 설정 시 모든 bridge 요청에 Authorization: Bearer ${BRIDGE_API_TOKEN} 자동 부착.
# /callback 라우트는 영향 없음(HMAC 분리).
# BRIDGE_API_TOKEN=

# omx-bridge가 claude 모드일 때 job 완료 알림을 수신할 포트
# 미설정 시 12000-12999 범위에서 자동 할당 — 다중 Claude 세션 간 충돌 없음
# omx-bridge CLAUDE_NOTIFY_URL을 동적 할당 포트로 맞춰야 함
# WEBHOOK_PORT=12345

# Claude Code Channels preview 알림을 활성화하려면 true로 설정
# Claude Code 실행 시 channel loading 옵션도 별도로 필요
ENABLE_CLAUDE_CHANNEL=false

# omx_get_notifications를 호출하지 않을 때 공유 JSONL store에 보관할 최대 완료 알림 수
MAX_NOTIFICATION_QUEUE_SIZE=200

# omx_submit_job_and_wait / omx_wait_for_job 기본 대기 설정
# 작업별 tool input의 waitTimeoutMs / pollIntervalMs로 덮어쓸 수 있음
OMX_DISPATCH_WAIT_TIMEOUT_MS=300000
OMX_DISPATCH_WAIT_POLL_INTERVAL_MS=1000

# 완료 알림 큐 영속화 파일(JSONL). 같은 작업 디렉터리의 여러 omx-dispatch
# 프로세스는 기본적으로 이 파일을 공유하고, omx_get_notifications가 file lock +
# job id dedupe로 한 번만 drain한다. 세션별 완전 격리가 필요할 때만 경로를 분리한다.
# 미설정 시 현재 작업 디렉터리 기준 .omx/state/omx-dispatch-notifications.jsonl 사용.
# OMX_DISPATCH_NOTIFICATION_STORE_PATH=/path/to/omx-bridge/.omx/state/omx-dispatch-notifications.jsonl
